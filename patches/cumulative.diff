+			/*
+			 * Darwin/LP64 port: original code cast char* to int
+			 * before printing via %s. Silent on 32-bit ILP32,
+			 * pointer-truncation UB on LP64. Format is %s, args
+			 * are already char*, so the casts were harmful noise.
+			 * -- Heirloom Darwin port.
+			 */
 			file_lock_error(msg, name, NOCATGETS("symlink(%s, %s)"),
-			    (int) name, (int) lockname);
+			    name, lockname);
 			fprintf(stderr, "%s", msg);
 			return errno;
 		}
